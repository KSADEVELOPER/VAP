# # Analytics Platform - Apache Configuration
# # منصة تحليل الزوار - إعدادات Apache

# # Enable URL Rewriting
# RewriteEngine On

# # Force HTTPS (إجبار HTTPS)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# # Remove www from domain (إزالة www من النطاق)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# # Security Headers (رؤوس الأمان)
# <IfModule mod_headers.c>
#     # Prevent clickjacking (منع الاختطاف)
#     Header always append X-Frame-Options SAMEORIGIN
    
#     # XSS Protection (حماية من XSS)
#     Header set X-XSS-Protection "1; mode=block"
    
#     # Content Type Options (خيارات نوع المحتوى)
#     Header set X-Content-Type-Options nosniff
    
#     # Referrer Policy (سياسة المرجع)
#     Header set Referrer-Policy "strict-origin-when-cross-origin"
    
#     # Content Security Policy (سياسة أمان المحتوى)
#     Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'"
    
#     # HSTS (HTTP Strict Transport Security)
#     Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
#     # Powered by header (إخفاء معلومات الخادم)
#     Header unset X-Powered-By
#     Header unset Server
# </IfModule>

# # Hide Server Information (إخفاء معلومات الخادم)
# <IfModule mod_security.c>
#     SecServerSignature Off
#     SecRuleEngine Off
# </IfModule>

